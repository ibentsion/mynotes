# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# uv / venv
.venv/
.python-version.local

# Personal data (privacy-sensitive — never commit)
data/pdfs/*
data/pages/*
data/crops/*
!data/pdfs/.gitkeep
!data/pages/.gitkeep
!data/crops/.gitkeep

# Pipeline outputs
outputs/*
!outputs/.gitkeep

# ClearML
.clearml/
clearml.conf.local

# Ruff / pytest / ty cache
.ruff_cache/
.pytest_cache/
.ty_cache/
